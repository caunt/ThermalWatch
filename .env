#!/usr/bin/env bash

if [[ ${BASH_SOURCE[0]} == "$0" ]]; then
    printf 'Source this script so the variables apply immediately: source ./.env\n' >&2
    exit 1
fi

thermalwatch_configure_env() {
    local map_key bot_token google_key channel_id countries
    local config_file config_dir profile_file quoted_config source_line temp_file

    while :; do
        read -r -s -p 'FIRMS_MAP_KEY (required): ' map_key || return 1
        printf '\n'
        if [[ $map_key =~ ^[A-Za-z0-9]{32}$ ]]; then
            break
        fi
        printf 'Enter exactly 32 ASCII letters or digits.\n' >&2
    done

    read -r -s -p 'TELEGRAM_BOT_TOKEN (optional): ' bot_token || return 1
    printf '\n'
    read -r -s -p 'GOOGLE_MAPS_API_KEY (optional): ' google_key || return 1
    printf '\n'
    read -r -p 'TELEGRAM_CHANNEL_ID [@cso_ukr]: ' channel_id || return 1
    read -r -p 'FIRMS_COUNTRIES [UKR,RUS]: ' countries || return 1
    channel_id=${channel_id:-@cso_ukr}
    countries=${countries:-UKR,RUS}

    config_file=${THERMALWATCH_ENV_FILE:-${XDG_CONFIG_HOME:-$HOME/.config}/thermalwatch/.env}
    config_dir=$(dirname "$config_file") || return 1

    (
        umask 077
        mkdir -p "$config_dir" || exit 1
        temp_file=$(mktemp "$config_file.XXXXXX") || exit 1
        {
            printf '# Generated by the ThermalWatch .env setup script.\n'
            printf 'export FIRMS_MAP_KEY=%q\n' "$map_key"
            printf 'export TELEGRAM_BOT_TOKEN=%q\n' "$bot_token"
            printf 'export GOOGLE_MAPS_API_KEY=%q\n' "$google_key"
            printf 'export TELEGRAM_CHANNEL_ID=%q\n' "$channel_id"
            printf 'export FIRMS_COUNTRIES=%q\n' "$countries"
        } >"$temp_file" || exit 1
        chmod 600 "$temp_file" || exit 1
        mv "$temp_file" "$config_file"
    ) || return 1

    if [[ -n ${THERMALWATCH_PROFILE_FILE:-} ]]; then
        profile_file=$THERMALWATCH_PROFILE_FILE
    elif [[ ${SHELL##*/} == zsh ]]; then
        profile_file="${ZDOTDIR:-$HOME}/.zshrc"
    elif [[ $(uname -s) == Darwin ]]; then
        profile_file="$HOME/.bash_profile"
    else
        profile_file="$HOME/.bashrc"
    fi

    printf -v quoted_config '%q' "$config_file"
    source_line="[[ -f $quoted_config ]] && source $quoted_config # ThermalWatch environment"
    mkdir -p "$(dirname "$profile_file")" || return 1
    touch "$profile_file" || return 1
    grep -Fqx -- "$source_line" "$profile_file" 2>/dev/null \
        || printf '\n%s\n' "$source_line" >>"$profile_file" \
        || return 1

    export FIRMS_MAP_KEY="$map_key"
    export TELEGRAM_BOT_TOKEN="$bot_token"
    export GOOGLE_MAPS_API_KEY="$google_key"
    export TELEGRAM_CHANNEL_ID="$channel_id"
    export FIRMS_COUNTRIES="$countries"

    printf 'Applied now and saved for future shell sessions in %s.\n' "$config_file"
}

if thermalwatch_configure_env; then
    unset -f thermalwatch_configure_env
    return 0
fi

unset -f thermalwatch_configure_env
return 1
