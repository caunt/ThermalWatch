#!/usr/bin/env bash

# Development-only helper. Source it; never store credentials in this file.
if [[ ${BASH_SOURCE[0]} == "$0" ]]; then
    printf 'Source this script so its temporary values remain active: source ./.env\n' >&2
    exit 1
fi

thermalwatch_prompt_env() {
    local map_key bot_token google_key channel_id countries

    while :; do
        read -r -s -p 'FIRMS_MAP_KEY (required): ' map_key || return 1
        printf '\n'
        if [[ $map_key =~ ^[A-Za-z0-9]{32}$ ]]; then
            break
        fi
        printf 'Enter exactly 32 ASCII letters or digits.\n' >&2
    done

    read -r -s -p 'TELEGRAM_BOT_TOKEN (optional): ' bot_token || return 1
    printf '\n'
    read -r -s -p 'GOOGLE_MAPS_API_KEY (optional): ' google_key || return 1
    printf '\n'
    read -r -p 'TELEGRAM_CHANNEL_ID [@cso_ukr]: ' channel_id || return 1
    read -r -p 'FIRMS_COUNTRIES [UKR,RUS]: ' countries || return 1

    export FIRMS_MAP_KEY="$map_key"
    export TELEGRAM_BOT_TOKEN="$bot_token"
    export GOOGLE_MAPS_API_KEY="$google_key"
    export TELEGRAM_CHANNEL_ID="${channel_id:-@cso_ukr}"
    export FIRMS_COUNTRIES="${countries:-UKR,RUS}"

    printf 'Temporary ThermalWatch variables applied to this shell only.\n'
}

if thermalwatch_prompt_env; then
    unset -f thermalwatch_prompt_env
    return 0
fi

unset -f thermalwatch_prompt_env
return 1
